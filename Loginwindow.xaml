<Window x:Class="AutodeskIDMonitor.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sign In | Autodesk ID Monitor"
        Width="420" Height="580"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">

    <Border Background="White" CornerRadius="16" 
            BorderBrush="#E0E6ED" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="30" Opacity="0.15" ShadowDepth="0"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" Background="#F5F7FA" CornerRadius="16,16,0,0" Padding="20,14">
                <Grid MouseDown="TitleBar_MouseDown">
                    <TextBlock Text="Autodesk ID Monitor" 
                               FontSize="13" FontWeight="SemiBold" 
                               Foreground="#5A6578"/>
                    <Button Content="✕" 
                            HorizontalAlignment="Right" 
                            Background="Transparent" 
                            BorderThickness="0"
                            Foreground="#8492A6"
                            FontSize="16"
                            Cursor="Hand"
                            Click="CloseButton_Click"
                            Width="30" Height="30"/>
                </Grid>
            </Border>

            <!-- Content -->
            <StackPanel Grid.Row="1" Margin="40,30,40,40">
                
                <!-- Logo Section -->
                <StackPanel HorizontalAlignment="Center" Margin="0,0,0,30">
                    <Border Width="72" Height="72" CornerRadius="16" Margin="0,0,0,16">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#00A8E8" Offset="0"/>
                                <GradientStop Color="#0090C8" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect Color="#00A8E8" BlurRadius="25" Opacity="0.4" ShadowDepth="0"/>
                        </Border.Effect>
                        <TextBlock Text="T" FontSize="32" FontWeight="ExtraBold" 
                                   Foreground="White" 
                                   HorizontalAlignment="Center" 
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="TANGENT" FontSize="20" FontWeight="ExtraBold" 
                               Foreground="#0A0E14" HorizontalAlignment="Center"/>
                    <TextBlock Text="LANDSCAPE ARCHITECTURE" FontSize="9" 
                               Foreground="#8492A6" HorizontalAlignment="Center" 
                               Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Welcome Text -->
                <TextBlock Text="Welcome back" FontSize="18" FontWeight="Bold" 
                           Foreground="#12181F" HorizontalAlignment="Center" 
                           Margin="0,0,0,6"/>
                <TextBlock Text="Sign in to continue to ID Monitor" 
                           FontSize="13" Foreground="#8492A6" 
                           HorizontalAlignment="Center" Margin="0,0,0,28"/>

                <!-- Error Message -->
                <Border x:Name="ErrorBorder" Background="#FEE2E2" 
                        CornerRadius="8" Padding="14" Margin="0,0,0,20"
                        Visibility="Collapsed">
                    <TextBlock x:Name="ErrorText" Foreground="#DC2626" 
                               FontSize="13" TextWrapping="Wrap"/>
                </Border>

                <!-- Username Field -->
                <TextBlock Text="USERNAME" FontSize="11" FontWeight="Bold" 
                           Foreground="#12181F" Margin="0,0,0,8"/>
                <TextBox x:Name="UsernameTextBox" 
                         Style="{StaticResource ModernTextBoxStyle}"
                         Margin="0,0,0,18"/>

                <!-- Password Field -->
                <TextBlock Text="PASSWORD" FontSize="11" FontWeight="Bold" 
                           Foreground="#12181F" Margin="0,0,0,8"/>
                <PasswordBox x:Name="PasswordBox" 
                             Style="{StaticResource ModernPasswordBoxStyle}"
                             Margin="0,0,0,18"/>

                <!-- Remember Me & Forgot Password -->
                <Grid Margin="0,0,0,24">
                    <CheckBox x:Name="RememberMeCheckBox" 
                              Content="Remember me" 
                              Foreground="#5A6578" 
                              FontSize="13"/>
                    <TextBlock HorizontalAlignment="Right">
                        <Hyperlink x:Name="ForgotPasswordLink" 
                                   Click="ForgotPassword_Click"
                                   Foreground="#00A8E8"
                                   TextDecorations="None">
                            Forgot password?
                        </Hyperlink>
                    </TextBlock>
                </Grid>

                <!-- Sign In Button -->
                <Button x:Name="SignInButton" 
                        Content="Sign In" 
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="SignIn_Click"
                        Margin="0,0,0,20"/>

                <!-- Footer -->
                <TextBlock HorizontalAlignment="Center" Margin="0,20,0,0">
                    <Run Text="Need help? Contact " Foreground="#8492A6" FontSize="12"/>
                    <Hyperlink Foreground="#00A8E8" TextDecorations="None">
                        IT Support
                    </Hyperlink>
                </TextBlock>

            </StackPanel>
        </Grid>
    </Border>
</Window>
