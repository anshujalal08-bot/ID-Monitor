<Window x:Class="AutodeskIDMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        Title="Autodesk ID Monitor"
        Width="380" Height="450"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Visibility="Hidden">

    <Grid>
        <!-- System Tray Icon -->
        <tb:TaskbarIcon x:Name="TrayIcon"
                        ToolTipText="Autodesk ID Monitor"
                        TrayMouseDoubleClick="TrayIcon_TrayMouseDoubleClick">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="📊 Open Dashboard" Click="OpenDashboard_Click"/>
                    <MenuItem Header="👤 My Status" Click="ShowStatus_Click"/>
                    <Separator/>
                    <MenuItem Header="⚙️ Settings" Click="Settings_Click"/>
                    <MenuItem Header="📜 View Logs" Click="ViewLogs_Click"/>
                    <Separator/>
                    <MenuItem Header="🚪 Sign Out" Click="SignOut_Click"/>
                    <MenuItem Header="❌ Exit" Click="Exit_Click"/>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>

        <!-- Main Window Content -->
        <Border Background="White" CornerRadius="12" 
                BorderBrush="#E0E6ED" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="20" Opacity="0.1" ShadowDepth="0"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0" Background="#F5F7FA" CornerRadius="12,12,0,0" Padding="20,16"
                        MouseDown="Header_MouseDown">
                    <Grid>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="40" Height="40" CornerRadius="10" Margin="0,0,12,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#00A8E8" Offset="0"/>
                                        <GradientStop Color="#0090C8" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="T" FontSize="18" FontWeight="Bold" 
                                           Foreground="White" 
                                           HorizontalAlignment="Center" 
                                           VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="ID Monitor" FontSize="15" FontWeight="Bold" 
                                           Foreground="#12181F"/>
                                <TextBlock Text="Tangent Landscape Architecture" 
                                           FontSize="10" Foreground="#8492A6"/>
                            </StackPanel>
                        </StackPanel>
                        <Button Content="—" 
                                HorizontalAlignment="Right" 
                                Background="Transparent" 
                                BorderThickness="0"
                                Foreground="#8492A6"
                                FontSize="16"
                                Cursor="Hand"
                                Click="Minimize_Click"
                                Width="30" Height="30"/>
                    </Grid>
                </Border>

                <!-- Content -->
                <StackPanel Grid.Row="1" Margin="24,20">
                    
                    <!-- User Info -->
                    <Border Background="#F5F7FA" CornerRadius="12" Padding="20" Margin="0,0,0,20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <Border Grid.Column="0" Width="56" Height="56" CornerRadius="14" Margin="0,0,16,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#00A8E8" Offset="0"/>
                                        <GradientStop Color="#0090C8" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock x:Name="UserInitials" Text="AJ" 
                                           FontSize="20" FontWeight="Bold" 
                                           Foreground="White"
                                           HorizontalAlignment="Center" 
                                           VerticalAlignment="Center"/>
                            </Border>
                            
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock x:Name="UserNameText" Text="Anshu Jalaludeen" 
                                           FontSize="16" FontWeight="Bold" Foreground="#12181F"/>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <Ellipse x:Name="StatusDot" Width="8" Height="8" 
                                             Fill="#10B981" Margin="0,0,6,0"/>
                                    <TextBlock x:Name="StatusText" Text="Online" 
                                               FontSize="12" Foreground="#5A6578"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Current Activity -->
                    <TextBlock Text="CURRENT ACTIVITY" FontSize="10" FontWeight="Bold" 
                               Foreground="#8492A6" Margin="0,0,0,12"/>
                    
                    <Border Background="#F5F7FA" CornerRadius="10" Padding="16" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="💻" FontSize="20" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Machine" FontSize="11" Foreground="#8492A6"/>
                                <TextBlock x:Name="MachineNameText" Text="DESKTOP-001" 
                                           FontSize="13" FontWeight="SemiBold" Foreground="#12181F"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Background="#F5F7FA" CornerRadius="10" Padding="16" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="📁" FontSize="20" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Current Project" FontSize="11" Foreground="#8492A6"/>
                                <TextBlock x:Name="ProjectNameText" Text="No active project" 
                                           FontSize="13" FontWeight="SemiBold" Foreground="#12181F"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Background="#F5F7FA" CornerRadius="10" Padding="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="🕐" FontSize="20" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Server Time (DXB)" FontSize="11" Foreground="#8492A6"/>
                                <TextBlock x:Name="ServerTimeText" Text="--:--:-- AM" 
                                           FontSize="13" FontWeight="SemiBold" Foreground="#12181F"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                </StackPanel>

                <!-- Footer -->
                <Border Grid.Row="2" Background="#F5F7FA" CornerRadius="0,0,12,12" Padding="20,14">
                    <Grid>
                        <TextBlock Text="v2.3.0" FontSize="11" Foreground="#8492A6" 
                                   VerticalAlignment="Center"/>
                        <Button Content="Open Dashboard" 
                                HorizontalAlignment="Right"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Padding="16,8"
                                FontSize="12"
                                Click="OpenDashboard_Click"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
